#!/bin/bash

RANGE=4
number=$((RANDOM % RANGE))
case $number in
    0)
        cow="default"
        ;;
    1)
        cow="tux"
        ;;
    2)
        cow="koala"
        ;;
    3)
        cow="moose"
        ;;
esac

RANGE=2
number=$((RANDOM % RANGE))
case $number in
    0)
        command="cowsay"
        ;;
    1)
        command="cowthink"
        ;;
esac

fortune | $command -f "$cow"
